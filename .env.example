RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
PR_ANALYSIS_QUEUE=pr.analysis.requests
SLM_REQUEST_QUEUE=slm.requests

# GitHub integration
# For GitHub Actions, the built-in GITHUB_TOKEN is enough when the workflow grants:
# contents: read, pull-requests: read, issues: write
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=change-me
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28

# PR comments
# true = create/update the PR Quality Analyzer comment on the pull request timeline
POST_PR_COMMENT=true
# true = update the previous analyzer comment instead of creating duplicates
UPDATE_EXISTING_PR_COMMENT=true

REPORTS_DIR=/app/reports

MODEL_ID=Qwen/Qwen2.5-Coder-0.5B-Instruct
SLM_BACKEND=transformers
MAX_NEW_TOKENS=512
MAX_PATCH_CHARS=12000
